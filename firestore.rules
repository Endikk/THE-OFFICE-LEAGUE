rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function belongsToOffice(officeId) {
      return isAuth()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.officeId == officeId;
    }

    // ─── USERS ───
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ─── OFFICES ───
    match /offices/{officeId} {
      allow read: if belongsToOffice(officeId);
      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.membersCount == 1;
      allow update: if belongsToOffice(officeId);
      allow delete: if false;
    }

    // ─── MATCHES ───
    match /matches/{matchId} {
      allow read: if isAuth();
      // Écriture client pour mise à jour des scores en temps réel
      allow create: if false;
      allow update: if isAuth();
      allow delete: if false;
    }

    // ─── BETS ───
    match /bets/{betId} {
      allow read: if isAuth()
        && belongsToOffice(resource.data.officeId);
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && belongsToOffice(request.resource.data.officeId)
        && request.resource.data.status == 'pending'
        && request.resource.data.amount > 0;
      // Résolution client : seul un membre de l'office peut résoudre
      allow update: if isAuth()
        && belongsToOffice(resource.data.officeId);
      allow delete: if false;
    }

    // ─── POLLS ───
    match /polls/{pollId} {
      allow read: if isAuth()
        && belongsToOffice(resource.data.officeId);
      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid
        && belongsToOffice(request.resource.data.officeId);
      allow update: if isAuth()
        && belongsToOffice(resource.data.officeId);
      allow delete: if false;
    }

    // ─── LEADERBOARD ───
    match /leaderboard/{officeId} {
      allow read: if belongsToOffice(officeId);
      allow write: if false;

      match /rankings/{userId} {
        allow read: if belongsToOffice(officeId);
        // Membres de l'office peuvent mettre à jour le leaderboard
        allow write: if belongsToOffice(officeId);
      }
    }

    // ─── DUNDIE AWARDS ───
    match /dundieAwards/{awardId} {
      allow read: if isAuth()
        && belongsToOffice(resource.data.officeId);
      // Membres de l'office peuvent créer des awards (auto-attribués)
      allow create: if isAuth()
        && belongsToOffice(request.resource.data.officeId);
      allow update: if isAuth()
        && belongsToOffice(resource.data.officeId);
      allow delete: if false;
    }

    // ─── NOTIFICATIONS ───
    match /notifications/{notifId} {
      // Un user ne peut lire que ses propres notifications
      allow read: if isAuth()
        && resource.data.userId == request.auth.uid;
      // Tout user auth peut créer une notification (pour notifier d'autres membres)
      allow create: if isAuth();
      // Seul le destinataire peut marquer comme lu
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ─── API CACHE (pour stocker les résultats API-Football) ───
    match /apiCache/{cacheId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
  }
}
