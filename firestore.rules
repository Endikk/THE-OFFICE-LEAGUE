rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    // Vérifie que l'utilisateur appartient à l'office donné
    // en lisant le document user pour comparer officeId
    function belongsToOffice(officeId) {
      return isAuth()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.officeId == officeId;
    }

    // ─── USERS ───
    match /users/{userId} {
      // Tout user auth peut lire les profils (pour leaderboard, etc.)
      allow read: if isAuth();
      // Seul le propriétaire peut créer/modifier son propre doc
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ─── OFFICES ───
    match /offices/{officeId} {
      // Seuls les membres de cet office peuvent le lire
      allow read: if belongsToOffice(officeId);
      // Tout user auth peut créer un office
      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.membersCount == 1;
      // Seul un membre peut modifier (ex: membersCount sur join)
      allow update: if belongsToOffice(officeId);
      allow delete: if false;
    }

    // ─── MATCHES ───
    match /matches/{matchId} {
      // Tout user auth peut lire les matchs
      allow read: if isAuth();
      // Écriture réservée au backend / admin SDK
      allow write: if false;
    }

    // ─── BETS ───
    match /bets/{betId} {
      // Un user ne peut lire que les paris de son office
      allow read: if isAuth()
        && belongsToOffice(resource.data.officeId);
      // Créer un pari : user auth, c'est son userId, et il appartient à l'office
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && belongsToOffice(request.resource.data.officeId)
        && request.resource.data.status == 'pending'
        && request.resource.data.amount > 0;
      // Mise à jour (résolution) réservée au backend
      allow update: if false;
      allow delete: if false;
    }

    // ─── POLLS ───
    match /polls/{pollId} {
      // Lecture : membre de l'office
      allow read: if isAuth()
        && belongsToOffice(resource.data.officeId);
      // Création : membre de l'office
      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid
        && belongsToOffice(request.resource.data.officeId);
      // Update : membre de l'office (pour voter)
      allow update: if isAuth()
        && belongsToOffice(resource.data.officeId);
      allow delete: if false;
    }

    // ─── LEADERBOARD (subcollection) ───
    // Path: leaderboard/{officeId}/rankings/{userId}
    match /leaderboard/{officeId} {
      allow read: if belongsToOffice(officeId);
      allow write: if false; // géré par le backend

      match /rankings/{userId} {
        allow read: if belongsToOffice(officeId);
        // Écriture réservée au backend
        allow write: if false;
      }
    }

    // ─── DUNDIE AWARDS ───
    match /dundieAwards/{awardId} {
      // Lecture : membre de l'office du award
      allow read: if isAuth()
        && belongsToOffice(resource.data.officeId);
      // Écriture réservée au backend
      allow write: if false;
    }
  }
}
