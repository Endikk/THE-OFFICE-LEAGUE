rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuth()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function belongsToOffice(officeId) {
      return isAuth()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.officeId == officeId;
    }

    // ─── USERS ───
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      // Owner peut modifier son profil, admin peut promouvoir
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false;
    }

    // ─── OFFICES ───
    match /offices/{officeId} {
      allow read: if belongsToOffice(officeId);
      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.membersCount == 1;
      allow update: if belongsToOffice(officeId);
      allow delete: if false;
    }

    // ─── MATCHES (admin gère les matchs) ───
    match /matches/{matchId} {
      allow read: if isAuth();
      // Seul l'admin peut créer, modifier et supprimer les matchs
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── BETS ───
    match /bets/{betId} {
      allow read: if isAuth()
        && belongsToOffice(resource.data.officeId);
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && belongsToOffice(request.resource.data.officeId)
        && request.resource.data.status == 'pending'
        && request.resource.data.amount > 0;
      // Résolution : admin ou membre de l'office
      allow update: if isAdmin()
        || (isAuth() && belongsToOffice(resource.data.officeId));
      allow delete: if false;
    }

    // ─── POLLS ───
    match /polls/{pollId} {
      allow read: if isAuth()
        && belongsToOffice(resource.data.officeId);
      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid
        && belongsToOffice(request.resource.data.officeId);
      allow update: if isAuth()
        && belongsToOffice(resource.data.officeId);
      allow delete: if false;
    }

    // ─── LEADERBOARD ───
    match /leaderboard/{officeId} {
      allow read: if belongsToOffice(officeId);
      allow write: if false;

      match /rankings/{userId} {
        allow read: if belongsToOffice(officeId);
        allow write: if belongsToOffice(officeId);
      }
    }

    // ─── DUNDIE AWARDS ───
    match /dundieAwards/{awardId} {
      allow read: if isAuth()
        && belongsToOffice(resource.data.officeId);
      allow create: if isAuth()
        && belongsToOffice(request.resource.data.officeId);
      allow update: if isAuth()
        && belongsToOffice(resource.data.officeId);
      allow delete: if false;
    }

    // ─── NOTIFICATIONS ───
    match /notifications/{notifId} {
      allow read: if isAuth()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
  }
}
